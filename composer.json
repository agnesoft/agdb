{
    "name": "agnesoft/agdb_api",
    "type": "library",
    "description": "Agnesoft Graph Database API client for PHP",
    "keywords": [
        "openapitools",
        "openapi-generator",
        "openapi",
        "php",
        "sdk",
        "rest",
        "api"
    ],
    "homepage": "https://github.com/agnesoft/agdb",
    "license": "Apache-2.0",
    "autoload": {
        "classmap": [
            "agdb_api/php/src",
            "agdb_api/php/lib"
        ]
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "authors": [
        {
            "name": "Agnesoft",
            "homepage": "https://github.com/agnesoft/agdb"
        }
    ],
    "require": {
        "php": "^8",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7",
        "guzzlehttp/psr7": "^2"
    },
    "require-dev": {
        "phpunit/phpunit": "^13",
        "phpstan/phpstan": "^2"
    }
}
